# Track only the pickup/ project. Ignore everything else at the repo root —
# the vendored Moss repos (moss-main), the app scaffold (moss-hacker-starter),
# and the reference docs (project-dev).
/*
!/.gitignore
!/README.md
!/pickup/

# Never commit secrets, virtualenvs, or caches (even inside pickup/).
pickup/.env
**/.venv/
**/__pycache__/
*.pyc
*.pyo
.DS_Store
