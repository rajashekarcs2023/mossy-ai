LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss — semantic search / memory (https://docs.moss.dev/docs)
# MOSS_PROJECT_ID / MOSS_PROJECT_KEY are filled in at index/run time (Task 9).
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=knowledge
MOSS_MEMORY_INDEX_NAME=memory
MOSS_MODEL_ID=moss-minilm

# Qwen (Alibaba Model Studio) — OPTIONAL. If QWEN_API_KEY is set, the whole agent
# team runs on Qwen (strong multilingually); otherwise it uses LiveKit Inference.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
